@model List<VisitorEntrySystem.Models.VisitorRecord>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <style>
        body {
            font-family: Arial;
            margin: 0;
        }

        nav {
            background: black;
            padding: 10px 20px;
            color: white;
            display: flex;
            justify-content: space-between;
        }

            nav a {
                color: white;
                margin-left: 15px;
                text-decoration: none;
            }

        .container {
            padding: 20px;
        }

        .stats {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .stat {
            border: 1px solid black;
            padding: 10px 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: black;
            color: white;
            padding: 8px;
            text-align: left;
        }

        td {
            padding: 8px;
            border-bottom: 1px solid #ddd;
        }
    </style>
</head>
<body>
    <nav>
        <span>Visitor Entry System</span>
        <div>
            <a href="/Admin/Dashboard">Dashboard</a>
            <a href="/Admin/ManageUsers">Manage Users</a>
            <a href="/Visitor/Index">Visitors</a>
            <a href="/Account/Logout">Logout</a>
        </div>
    </nav>
    <div class="container">
        <div class="stats">
            <div class="stat">Total: <strong>@Model.Count</strong></div>
            <div class="stat">Inside: <strong>@Model.Count(v => !v.HasCheckedOut())</strong></div>
            <div class="stat">Checked Out: <strong>@Model.Count(v => v.HasCheckedOut())</strong></div>
        </div>
        <form method="get" style="margin-bottom:10px;">
            <input type="text" name="search" value="@ViewBag.Search" placeholder="Search name..." />
            <button type="submit">Search</button>
            <a href="/Admin/Dashboard">Clear</a>
        </form>
        <table>
            <tr><th>Name</th><th>Contact</th><th>Purpose</th><th>Host</th><th>Check In</th><th>Check Out</th><th>By</th><th>Status</th></tr>
            @foreach (var v in Model)
            {
                <tr>
                    <td>@v.FullName</td>
                    <td>@v.ContactNumber</td>
                    <td>@v.Purpose</td>
                    <td>@v.HostName</td>
                    <td>@v.CheckInTime.ToString("MMM dd, HH:mm")</td>
                    <td>@(v.CheckOutTime.HasValue? v.CheckOutTime.Value.ToString("MMM dd, HH:mm") : "—")</td>
                    <td>@v.RegisteredBy</td>
                    <td>@(v.HasCheckedOut() ? "Out" : "Inside")</td>
                </tr>
            }
        </table>
    </div>
</body>
</html>
@model List<VisitorEntrySystem.Models.User>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Manage Users</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f0f4ff;
        }

        .navbar {
            background: white;
            padding: 0 32px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

            .navbar .brand {
                font-size: 17px;
                font-weight: 700;
                color: #1a73e8;
            }

            .navbar .links {
                display: flex;
                align-items: center;
                gap: 24px;
            }

            .navbar a {
                color: #1a73e8;
                text-decoration: none;
                font-size: 14px;
                font-weight: 500;
            }

            .navbar .logout {
                color: #d93025 !important;
            }

        .container {
            max-width: 700px;
            margin: 40px auto;
            padding: 0 24px;
        }

        .back {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #1a73e8;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 20px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

            .page-header h2 {
                font-size: 22px;
                color: #1a1a2e;
                font-weight: 700;
            }

        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: 0.2s;
        }

        .btn-primary {
            background: #1a73e8;
            color: white;
        }

            .btn-primary:hover {
                background: #1557b0;
            }

        .btn-sm {
            padding: 6px 14px;
            font-size: 12px;
            border-radius: 6px;
        }

        .btn-delete {
            background: #fce8e6;
            color: #d93025;
        }

        .card {
            background: white;
            border-radius: 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: #1a73e8;
            color: white;
            padding: 13px 16px;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
        }

        td {
            padding: 13px 16px;
            font-size: 13px;
            color: #333;
            border-bottom: 1px solid #f5f5f5;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background: #f8faff;
        }

        .role-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .role-admin {
            background: #e8f0fe;
            color: #1a73e8;
        }

        .role-receptionist {
            background: #e6f4ea;
            color: #1e8e3e;
        }
    </style>
</head>
<body>
    <div class="navbar">
        <span class="brand">🏢 Visitor Entry System</span>
        <div class="links">
            <a href="/Admin/Dashboard">Dashboard</a>
            <a href="/Admin/ManageUsers">Manage Users</a>
            <a href="/Account/Logout" class="logout">Logout</a>
        </div>
    </div>
    <div class="container">
        <a href="/Admin/Dashboard" class="back">← Back to Dashboard</a>
        <div class="page-header">
            <h2>Manage Users</h2>
            <a href="/Admin/AddUser" class="btn btn-primary">+ Add User</a>
        </div>
        <div class="card">
            <table>
                <tr><th>ID</th><th>Full Name</th><th>Username</th><th>Email</th><th>Phone</th><th>Role</th><th>Action</th></tr>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Id</td>
                        <td><strong>@(u.FullName ?? "—")</strong></td>
                        <td>@u.Username</td>
                        <td>@(u.Email ?? "—")</td>
                        <td>@(u.Phone ?? "—")</td>
                        <td><span class="role-badge @(u.Role == "Admin" ? "role-admin" : "role-receptionist")">@u.Role</span></td>
                        <td><a href="/Admin/DeleteUser/@u.Id" class="btn btn-sm btn-delete" onclick="return confirm('Delete this user?')">Delete</a></td>
                    </tr>
                }
            </table>
        </div>
    </div>
</body>
</html>
@model List<VisitorEntrySystem.Models.User>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Manage Users</title>
    <style>
        body {
            font-family: Arial;
            margin: 0;
        }

        nav {
            background: black;
            padding: 10px 20px;
            color: white;
            display: flex;
            justify-content: space-between;
        }

            nav a {
                color: white;
                margin-left: 15px;
                text-decoration: none;
            }

        .container {
            padding: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: black;
            color: white;
            padding: 8px;
            text-align: left;
        }

        td {
            padding: 8px;
            border-bottom: 1px solid #ddd;
        }

        .btn {
            padding: 5px 10px;
            background: black;
            color: white;
            text-decoration: none;
            font-size: 13px;
        }

        .del {
            padding: 5px 10px;
            background: white;
            border: 1px solid black;
            text-decoration: none;
            font-size: 13px;
        }
    </style>
</head>
<body>
    <nav>
        <span>Visitor Entry System</span>
        <div>
            <a href="/Admin/Dashboard">Dashboard</a>
            <a href="/Admin/ManageUsers">Manage Users</a>
            <a href="/Account/Logout">Logout</a>
        </div>
    </nav>
    <div class="container">
        <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
            <h3 style="margin:0;">Users</h3>
            <a href="/Admin/AddUser" class="btn">+ Add User</a>
        </div>
        <table>
            <tr><th>ID</th><th>Name</th><th>Username</th><th>Email</th><th>Phone</th><th>Role</th><th>Action</th></tr>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.Id</td>
                    <td>@(u.FullName ?? "—")</td>
                    <td>@u.Username</td>
                    <td>@(u.Email ?? "—")</td>
                    <td>@(u.Phone ?? "—")</td>
                    <td>@u.Role</td>
                    <td><a href="/Admin/DeleteUser/@u.Id" class="del" onclick="return confirm('Delete?')">Delete</a></td>
                </tr>
            }
        </table>
    </div>
</body>
</html>
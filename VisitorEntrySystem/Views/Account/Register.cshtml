@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Admin Setup</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f0f4ff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 40px 0;
        }

        .card {
            background: white;
            padding: 40px;
            border-radius: 16px;
            width: 420px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        }

        .logo {
            text-align: center;
            margin-bottom: 20px;
        }

            .logo h1 {
                font-size: 20px;
                color: #1a73e8;
                font-weight: 700;
            }

            .logo p {
                color: #888;
                font-size: 13px;
                margin-top: 4px;
            }

        .badge {
            background: #e8f0fe;
            color: #1a73e8;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            display: inline-block;
            margin-top: 8px;
        }

        .divider {
            height: 1px;
            background: #f0f0f0;
            margin: 20px 0;
        }

        .section-title {
            font-size: 12px;
            color: #aaa;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 14px;
        }

        label {
            font-size: 13px;
            color: #555;
            font-weight: 600;
            display: block;
            margin-bottom: 6px;
        }

        input {
            width: 100%;
            padding: 11px 14px;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            font-size: 14px;
            margin-bottom: 16px;
            transition: border 0.2s;
        }

            input:focus {
                outline: none;
                border-color: #1a73e8;
            }

        button {
            width: 100%;
            padding: 12px;
            background: #1a73e8;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

            button:hover {
                background: #1557b0;
            }

        .error {
            background: #fff0f0;
            color: #d93025;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 16px;
            border: 1px solid #fad2cf;
        }

        .success {
            background: #e6f4ea;
            color: #1e8e3e;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 16px;
            border: 1px solid #ceead6;
        }

        .login-link {
            text-align: center;
            margin-top: 16px;
            font-size: 13px;
            color: #888;
        }

            .login-link a {
                color: #1a73e8;
                text-decoration: none;
                font-weight: 600;
            }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo">
            <h1>🏢 Visitor Entry System</h1>
            <p>First-time setup</p>
            <span class="badge">Admin Account Creation</span>
        </div>
        <div class="divider"></div>
        @if (ViewBag.Error != null)
        {
            <div class="error">⚠️ @ViewBag.Error</div>
        }
        @if (ViewBag.Success != null)
        {
            <div class="success">
                ✅ @ViewBag.Success
                <br /><a href="/Account/Login" style="color:#1e8e3e; font-weight:600;">Click here to login →</a>
            </div>
        }
        else
        {
            <form method="post">
                <div class="section-title">Personal Info</div>
                <label>Full Name</label>
                <input type="text" name="FullName" placeholder="Your full name" required />
                <label>Email</label>
                <input type="email" name="Email" placeholder="your@email.com" required />
                <label>Phone</label>
                <input type="text" name="Phone" placeholder="Your phone number" required />
                <div class="divider"></div>
                <div class="section-title">Account Credentials</div>
                <label>Username</label>
                <input type="text" name="Username" placeholder="Choose a username" required />
                <label>Password</label>
                <input type="password" name="PasswordHash" placeholder="Choose a strong password" required />
                <button type="submit">Create Admin Account →</button>
            </form>
        }
        <div class="login-link">
            Already have an account? <a href="/Account/Login">Sign in</a>
        </div>
    </div>
</body>
</html>
@model VisitorEntrySystem.Models.VisitorRecord
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Edit Visitor</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f0f4ff;
        }

        .navbar {
            background: white;
            padding: 0 32px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

            .navbar .brand {
                font-size: 17px;
                font-weight: 700;
                color: #1a73e8;
            }

            .navbar a {
                color: #1a73e8;
                text-decoration: none;
                font-size: 14px;
                font-weight: 500;
            }

        .container {
            max-width: 560px;
            margin: 40px auto;
            padding: 0 24px;
        }

        .back {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #1a73e8;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 20px;
        }

            .back:hover {
                text-decoration: underline;
            }

        .card {
            background: white;
            border-radius: 14px;
            padding: 36px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }

            .card h2 {
                font-size: 20px;
                color: #1a1a2e;
                margin-bottom: 24px;
                font-weight: 700;
            }

        label {
            font-size: 13px;
            color: #555;
            font-weight: 600;
            display: block;
            margin-bottom: 6px;
        }

        input {
            width: 100%;
            padding: 11px 14px;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            font-size: 14px;
            margin-bottom: 18px;
            transition: border 0.2s;
        }

            input:focus {
                outline: none;
                border-color: #1a73e8;
            }

        .btn-row {
            display: flex;
            gap: 12px;
            margin-top: 8px;
        }

        .btn {
            padding: 11px 24px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-block;
            transition: 0.2s;
        }

        .btn-primary {
            background: #1a73e8;
            color: white;
        }

            .btn-primary:hover {
                background: #1557b0;
            }

        .btn-ghost {
            background: #f1f3f4;
            color: #555;
        }

            .btn-ghost:hover {
                background: #e0e0e0;
            }
    </style>
</head>
<body>
    <div class="navbar">
        <span class="brand">🏢 Visitor Entry System</span>
        <a href="/Visitor/Index">← Back to List</a>
    </div>
    <div class="container">
        <a href="/Visitor/Index" class="back">← Back to Visitor List</a>
        <div class="card">
            <h2>Edit Visitor</h2>
            <form method="post">
                <input type="hidden" name="Id" value="@Model.Id" />
                <input type="hidden" name="CheckInTime" value="@Model.CheckInTime" />
                <input type="hidden" name="CheckOutTime" value="@Model.CheckOutTime" />
                <input type="hidden" name="RegisteredBy" value="@Model.RegisteredBy" />
                <input type="hidden" name="CreatedAt" value="@Model.CreatedAt" />
                <label>Full Name</label>
                <input type="text" name="FullName" value="@Model.FullName" required />
                <label>Contact Number</label>
                <input type="text" name="ContactNumber" value="@Model.ContactNumber" required />
                <label>Purpose of Visit</label>
                <input type="text" name="Purpose" value="@Model.Purpose" required />
                <label>Host Name</label>
                <input type="text" name="HostName" value="@Model.HostName" required />
                <div class="btn-row">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a href="/Visitor/Index" class="btn btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
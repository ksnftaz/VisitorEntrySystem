@model VisitorEntrySystem.Models.VisitorRecord
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Edit Visitor</title>
    <style>
        body {
            font-family: Arial;
            margin: 0;
        }

        nav {
            background: black;
            padding: 10px 20px;
            color: white;
            display: flex;
            justify-content: space-between;
        }

            nav a {
                color: white;
                text-decoration: none;
            }

        .container {
            padding: 20px;
            max-width: 400px;
        }

        input {
            width: 100%;
            padding: 7px;
            margin-bottom: 10px;
            box-sizing: border-box;
        }

        button {
            padding: 8px 20px;
            background: black;
            color: white;
            border: none;
            cursor: pointer;
        }

        a.cancel {
            padding: 8px 20px;
            border: 1px solid black;
            text-decoration: none;
            color: black;
        }
    </style>
</head>
<body>
    <nav>
        <span>Visitor Entry System</span>
        <a href="/Visitor/Index">Back</a>
    </nav>
    <div class="container">
        <h3>Edit Visitor</h3>
        <form method="post">
            <input type="hidden" name="Id" value="@Model.Id" />
            <input type="hidden" name="CheckInTime" value="@Model.CheckInTime" />
            <input type="hidden" name="CheckOutTime" value="@Model.CheckOutTime" />
            <input type="hidden" name="RegisteredBy" value="@Model.RegisteredBy" />
            <input type="hidden" name="CreatedAt" value="@Model.CreatedAt" />
            <input type="text" name="FullName" value="@Model.FullName" required />
            <input type="text" name="ContactNumber" value="@Model.ContactNumber" required />
            <input type="text" name="Purpose" value="@Model.Purpose" required />
            <input type="text" name="HostName" value="@Model.HostName" required />
            <div style="display:flex; gap:10px;">
                <button type="submit">Save</button>
                <a href="/Visitor/Index" class="cancel">Cancel</a>
            </div>
        </form>
    </div>
</body>
</html>
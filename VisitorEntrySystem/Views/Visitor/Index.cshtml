@model List<VisitorEntrySystem.Models.VisitorRecord>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Visitors</title>
    <style>
        body {
            font-family: Arial;
            margin: 0;
        }

        nav {
            background: black;
            padding: 10px 20px;
            color: white;
            display: flex;
            justify-content: space-between;
        }

            nav a {
                color: white;
                margin-left: 15px;
                text-decoration: none;
            }

        .container {
            padding: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: black;
            color: white;
            padding: 8px;
            text-align: left;
        }

        td {
            padding: 8px;
            border-bottom: 1px solid #ddd;
        }

        .btn {
            padding: 5px 10px;
            background: black;
            color: white;
            text-decoration: none;
            font-size: 13px;
        }

        .sm {
            padding: 4px 8px;
            border: 1px solid black;
            text-decoration: none;
            color: black;
            font-size: 12px;
        }
    </style>
</head>
<body>
    <nav>
        <span>Visitor Entry System — Hi, @Context.Session.GetString("Username")</span>
        <a href="/Account/Logout" style="color:white; text-decoration:none;">Logout</a>
    </nav>
    <div class="container">
        <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
            <h3 style="margin:0;">Visitor Records</h3>
            <a href="/Visitor/Create" class="btn">+ Register Visitor</a>
        </div>
        <table>
            <tr><th>Name</th><th>Contact</th><th>Purpose</th><th>Host</th><th>Check In</th><th>Check Out</th><th>Status</th><th>Actions</th></tr>
            @foreach (var v in Model)
            {
                <tr>
                    <td>@v.FullName</td>
                    <td>@v.ContactNumber</td>
                    <td>@v.Purpose</td>
                    <td>@v.HostName</td>
                    <td>@v.CheckInTime.ToString("MMM dd, HH:mm")</td>
                    <td>@(v.CheckOutTime.HasValue? v.CheckOutTime.Value.ToString("MMM dd, HH:mm") : "—")</td>
                    <td>@(v.HasCheckedOut() ? "Out" : "Inside")</td>
                    <td>
                        <a href="/Visitor/Edit/@v.Id" class="sm">Edit</a>
                        @if (Context.Session.GetString("Role") == "Admin")
                        {
                            <a href="/Visitor/Delete/@v.Id" class="sm" onclick="return confirm('Delete?')">Delete</a>
                        }
                        @if (!v.HasCheckedOut())
                        {
                            <a href="/Visitor/CheckOut/@v.Id" class="sm">Check Out</a>
                        }
                    </td>
                </tr>
            }
        </table>
    </div>
</body>
</html>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Register Visitor</title>
    <style>
        body {
            font-family: Arial;
            margin: 0;
        }

        nav {
            background: black;
            padding: 10px 20px;
            color: white;
            display: flex;
            justify-content: space-between;
        }

            nav a {
                color: white;
                text-decoration: none;
            }

        .container {
            padding: 20px;
            max-width: 400px;
        }

        input {
            width: 100%;
            padding: 7px;
            margin-bottom: 10px;
            box-sizing: border-box;
        }

        button {
            padding: 8px 20px;
            background: black;
            color: white;
            border: none;
            cursor: pointer;
        }

        a.cancel {
            padding: 8px 20px;
            border: 1px solid black;
            text-decoration: none;
            color: black;
        }
    </style>
</head>
<body>
    <nav>
        <span>Visitor Entry System</span>
        <a href="/Visitor/Index">Back</a>
    </nav>
    <div class="container">
        <h3>Register Visitor</h3>
        <form method="post">
            <input type="text" name="FullName" placeholder="Full Name" required />
            <input type="text" name="ContactNumber" placeholder="Contact Number" required />
            <input type="text" name="Purpose" placeholder="Purpose of Visit" required />
            <input type="text" name="HostName" placeholder="Host Name" required />
            <div style="display:flex; gap:10px;">
                <button type="submit">Register</button>
                <a href="/Visitor/Index" class="cancel">Cancel</a>
            </div>
        </form>
    </div>
</body>
</html>